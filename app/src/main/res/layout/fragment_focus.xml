<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="20dp">

    <TextView
        android:id="@+id/text_view_session_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="96dp"
        android:text="@string/focus_mode"
        android:textColor="#2196F3"
        android:textSize="24sp"
        android:textStyle="bold"
        android:letterSpacing="0.2" />

    <TextView
        android:id="@+id/text_view_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/text_view_session_type"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:text="@string/focus_timer_default"
        android:textColor="#212121"
        android:textSize="90sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_view_total_focus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/text_view_timer"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="25dp"
        android:text="@string/total_focus_default"
        android:alpha="0.6"
        android:textSize="20sp" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_silence_notifications"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/text_view_total_focus"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="@string/silence_notifications_during_focus" />

    <TextView
        android:id="@+id/text_view_dnd_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/switch_silence_notifications"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:text="@string/dnd_status_off"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/button_start_pause"
            android:layout_width="85dp"
            android:layout_height="85dp"
            android:layout_marginEnd="30dp"
            android:background="@drawable/circle_button"
            app:backgroundTint="@null"
            android:contentDescription="@string/content_desc_start_pause"
            android:src="@android:drawable/ic_media_play"
            app:tint="#FFFFFF"
            android:elevation="6dp"
            android:stateListAnimator="@null" />

        <ImageButton
            android:id="@+id/button_stop"
            android:layout_width="85dp"
            android:layout_height="85dp"
            android:alpha="0.6"
            android:background="@drawable/circle_button"
            android:contentDescription="@string/content_desc_stop"
            android:elevation="6dp"
            android:padding="28dp"
            android:src="@drawable/ic_media_stop"
            android:stateListAnimator="@null"
            app:backgroundTint="@null"
            app:tint="#FFFFFF" />
    </LinearLayout>

</RelativeLayout>