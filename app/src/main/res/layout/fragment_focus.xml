<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Scrollable content area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/focus_subtitle"
                android:textColor="#6B7280"
                android:textSize="13sp" />

            <!-- Mode selector -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_focus_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:checkedButton="@id/btn_mode_pomodoro"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_mode_pomodoro"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/focus_mode_pomodoro"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_mode_infinite"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/focus_mode_infinite"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_mode_countdown"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/focus_mode_countdown"
                    android:textSize="12sp" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Countdown duration picker (visible only in Countdown mode) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_countdown_duration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFFBF0"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#FDE68A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/countdown_duration_label"
                            android:textColor="#92400E"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/text_countdown_duration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/countdown_duration_default"
                            android:textColor="#111827"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tap_to_change"
                        android:textColor="#D97706"
                        android:textSize="12sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Timer card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#F0F9FF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#BFDBFE"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="28dp"
                    android:paddingBottom="24dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <TextView
                        android:id="@+id/text_view_session_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/focus_mode"
                        android:textColor="#2196F3"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12" />

                    <TextView
                        android:id="@+id/text_view_timer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="@string/focus_timer_default"
                        android:textColor="#111827"
                        android:textSize="72sp"
                        android:textStyle="bold"
                        android:includeFontPadding="false"
                        app:autoSizeMaxTextSize="72sp"
                        app:autoSizeMinTextSize="32sp"
                        app:autoSizeTextType="uniform" />

                    <TextView
                        android:id="@+id/text_view_total_focus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/total_focus_default"
                        android:textColor="#1D4ED8"
                        android:textSize="14sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- DND / Silence notifications card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#F8FAFC"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_silence_notifications"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/silence_notifications_during_focus"
                        android:textColor="#111827"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/text_view_dnd_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/dnd_status_off"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Action buttons — pinned at bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="16dp"
        android:paddingBottom="28dp"
        android:paddingStart="32dp"
        android:paddingEnd="32dp">

        <ImageButton
            android:id="@+id/button_start_pause"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_marginEnd="28dp"
            android:background="@drawable/circle_button"
            android:contentDescription="@string/content_desc_start_pause"
            android:elevation="4dp"
            android:src="@android:drawable/ic_media_play"
            android:stateListAnimator="@null"
            app:backgroundTint="@null"
            app:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/button_stop"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:alpha="0.65"
            android:background="@drawable/circle_button"
            android:contentDescription="@string/content_desc_stop"
            android:elevation="4dp"
            android:padding="26dp"
            android:src="@drawable/ic_media_stop"
            android:stateListAnimator="@null"
            app:backgroundTint="@null"
            app:tint="#FFFFFF" />

    </LinearLayout>

</LinearLayout>
