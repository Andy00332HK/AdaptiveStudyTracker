<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/import_top_app_bar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="@string/import_from_calendar"
        app:navigationIcon="?attr/homeAsUpIndicator"
        style="@style/Widget.MaterialComponents.Toolbar.Primary" />

    <TextView
        android:id="@+id/text_empty_calendar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_upcoming_events"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_events"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:id="@+id/layout_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:elevation="8dp"
        android:background="?android:colorBackground">

        <CheckBox
            android:id="@+id/checkbox_select_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_all" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_import_selected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/import_selected"
            app:icon="@android:drawable/ic_input_add" />

    </LinearLayout>

</LinearLayout>