<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_usage"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/text_usage_limit_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/daily_usage_limit_default"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/seekbar_usage_limit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="720"
            android:progress="120"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_sleep"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/bedtime_label" />

            <Button
                android:id="@+id/button_sleep_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="23:00"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/wakeup_label" />

            <Button
                android:id="@+id/button_sleep_end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="07:00"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        </LinearLayout>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_notifications"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_task_reminders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/enable_task_reminders"
            android:checked="true"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_usage_warnings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/enable_usage_warnings"
            android:checked="true"
            android:layout_marginBottom="16dp" />


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_tracking"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_usage_tracking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/enable_usage_tracking"
            android:checked="false"
            android:layout_marginBottom="24dp" />


        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_share_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/share_daily_summary"
            app:icon="@android:drawable/ic_menu_share"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>
</ScrollView>